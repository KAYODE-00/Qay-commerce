# PostgreSQL database used by Medusa.
# Local example: postgres://postgres:postgres@localhost:5432/medusa-dtc-starter
DATABASE_URL=

# Redis is recommended for production event/workflow/background processing.
# Local example: redis://localhost:6379
REDIS_URL="redis://localhost:6379"

# Generate unique 32+ character secrets per environment.
JWT_SECRET=
COOKIE_SECRET=

# Browser origins allowed to call Store API routes.
STORE_CORS=http://localhost:8000,http://localhost:3000,http://localhost:3002,https://qay-theta.vercel.app

# Browser origins allowed to use Medusa Admin and auth flows.
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://qay-theta.vercel.app
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000,http://localhost:3000,http://localhost:3002,https://qay-theta.vercel.app

# Public backend URL used by storefronts and external clients.
MEDUSA_BACKEND_URL=http://localhost:9000

# Storefront URLs that may connect to this backend.
STOREFRONT_URL=http://localhost:8000
QAY_LOCAL_URL=http://localhost:3000
QAY_LOCAL_ALT_URL=http://localhost:3002
QAY_PRODUCTION_URL=https://qay-theta.vercel.app

# Stripe is not enabled in this backend by default. Use test-mode values only
# after adding/configuring @medusajs/payment-stripe in medusa-config.ts.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CAPTURE=false
STRIPE_AUTOMATIC_PAYMENT_METHODS=false

# Optional QAY webhook receiver for commerce events.
QAY_WEBHOOK_URL=
QAY_WEBHOOK_SECRET=
